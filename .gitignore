# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle
/vendor/bundle/*
!/vendor/bundle/.keep

# Ignore all logfiles.
/log/*
!/log/.keep
!/log/nginx/
/log/nginx/*
!/log/nginx/.keep

# Ignore tempfiles.
/tmp/*
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

/public/assets

# Ignore Byebug command history file.
.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key

# dotenv
.env

# backup
/backup/*
!/backup/.keep
!/backup/README.md

# webpacker
/public/packs
/public/packs-test
/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# others
.DS_Store
Thumbs.db
.gitignore
AGENTS.md
context.md
docker-compose.gce.yml
docker-compose.production.yml
docker-compose.yml
README.md
app/controllers/items_controller.rb
app/controllers/machines_controller.rb
app/helpers/pagination_helper.rb
app/views/items/_tree_row.html.slim
app/views/items/index.html.slim
app/views/machines/index.html.slim
bin/capture_tree_view_screenshots
docker/app/Dockerfile
docker/web/Dockerfile
docker/web/nginx/nginx.conf
spec/rails_helper.rb
spec/requests/items_spec.rb
spec/requests/machines_spec.rb
spec/system/tree_view_screenshots_spec.rb
spec/views/items/index.html.slim_spec.rb
