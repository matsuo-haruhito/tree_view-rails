<% visible_columns = local_assigns.fetch(:table_state, {}).fetch("visible_columns", local_assigns.fetch(:columns, [])) %>

<% visible_columns.each do |column| %>
  <td data-tree-view-interactive="false" data-rails-table-preferences-column-key="<%= column.fetch("key") %>">
    <% if respond_to?(:table_preferences_value) %>
      <%= table_preferences_value(item, column) %>
    <% elsif item.respond_to?(column.fetch("key")) %>
      <%= item.public_send(column.fetch("key")) %>
    <% end %>
  </td>
<% end %>
